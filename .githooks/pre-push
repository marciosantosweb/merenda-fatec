#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# pre-push hook: Auto-bumps pubspec.yaml version before each push.
#
# Convenção de mensagem de commit:
#   [MAJOR] minha mensagem   → bump major (X.0.0+build)
#   [MINOR] minha mensagem   → bump minor (x.Y.0+build)
#   qualquer outro texto     → bump patch (x.y.Z+build)
# ─────────────────────────────────────────────────────────────────────────────

PUBSPEC="mobile_app/pubspec.yaml"

# Verifica se o pubspec existe
if [ ! -f "$PUBSPEC" ]; then
  echo "⚠️  pubspec.yaml não encontrado em $PUBSPEC — versão não atualizada."
  exit 0
fi

# Lê versão atual (formato: 1.0.0+1)
CURRENT_LINE=$(grep '^version:' "$PUBSPEC")
CURRENT=$(echo "$CURRENT_LINE" | sed 's/version: //' | tr -d '[:space:]')
VERSION=$(echo "$CURRENT" | cut -d'+' -f1)
BUILD=$(echo "$CURRENT" | cut -d'+' -f2)

MAJOR=$(echo "$VERSION" | cut -d'.' -f1)
MINOR=$(echo "$VERSION" | cut -d'.' -f2)
PATCH=$(echo "$VERSION" | cut -d'.' -f3)

# Incrementa build number sempre
BUILD=$((BUILD + 1))

# Pega a mensagem do último commit
LAST_MSG=$(git log -1 --pretty=%B 2>/dev/null || echo "")

# Decide o tipo de bump pela mensagem
if echo "$LAST_MSG" | grep -qiE "^\[MAJOR\]"; then
  MAJOR=$((MAJOR + 1))
  MINOR=0
  PATCH=0
  BUMP_TYPE="MAJOR"
elif echo "$LAST_MSG" | grep -qiE "^\[MINOR\]"; then
  MINOR=$((MINOR + 1))
  PATCH=0
  BUMP_TYPE="MINOR"
else
  PATCH=$((PATCH + 1))
  BUMP_TYPE="PATCH"
fi

NEW_VERSION="$MAJOR.$MINOR.$PATCH+$BUILD"

# Atualiza pubspec.yaml (compatível com macOS e Linux)
sed -i '' "s/^version: .*/version: $NEW_VERSION/" "$PUBSPEC" 2>/dev/null || \
sed -i    "s/^version: .*/version: $NEW_VERSION/" "$PUBSPEC"

echo ""
echo "🚀 Auto-version bump [$BUMP_TYPE]"
echo "   $CURRENT  →  $NEW_VERSION"
echo ""

# Commita a alteração de versão
git add "$PUBSPEC"
git commit -m "chore: v$NEW_VERSION" --quiet

echo "✅ Versão $NEW_VERSION commitada automaticamente."
echo ""
